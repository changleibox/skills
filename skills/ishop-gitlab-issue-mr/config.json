{
  "name": "ishop-gitlab-issue-mr",
  "version": "1.2.0",
  "description": "iShop GitLab (git.graspishop.com) 仓库 Issue、Merge Request 和分支全生命周期管理技能，支持完整的开发工作流",
  "author": "Qoder",
  "category": "git_workflow",
  "tags": ["gitlab", "issue", "merge-request", "branch", "workflow", "code-review"],
  "dependencies": ["git", "glab"],
  "dependency_check": {
    "glab": {
      "check_command": "which glab && glab version",
      "install": {
        "macos": "brew install glab",
        "linux": "curl -sL https://raw.githubusercontent.com/profclems/glab/trunk/scripts/install.sh | sh"
      }
    }
  },
  "interaction": {
    "tool": "ask_user_question",
    "rule": "所有需要用户确认的操作，必须使用 ask_user_question 工具让用户选择，禁止静默执行"
  },
  "gitlab": {
    "url": "https://git.graspishop.com/",
    "token_config": {
      "check_priority": ["glab_auth", "git_config", "env_var"],
      "methods": [
        {
          "name": "glab_auth",
          "label": "🔑 glab auth 登录",
          "description": "通过 glab CLI 交互式登录",
          "check_command": "glab auth status",
          "set_command": "glab auth login"
        },
        {
          "name": "git_config",
          "label": "🔧 Git 全局配置（推荐）",
          "description": "永久保存，所有终端可用",
          "check_command": "git config --global gitlab.token",
          "set_command": "git config --global gitlab.token \"<token>\""
        },
        {
          "name": "env_var",
          "label": "🌍 环境变量",
          "description": "临时配置，仅当前终端有效",
          "check_command": "echo $GITLAB_TOKEN",
          "set_command": "export GITLAB_TOKEN=\"<token>\""
        },
        {
          "name": "create_new",
          "label": "❓ 我还没有 Token",
          "description": "引导创建 Token"
        }
      ],
      "create_url": "https://git.graspishop.com/-/profile/personal_access_tokens",
      "required_scopes": ["api"]
    }
  },
  "project_detection": {
    "method": "git_remote",
    "check_commands": [
      "git rev-parse --is-inside-work-tree",
      "git rev-parse --show-toplevel",
      "git remote get-url origin"
    ],
    "url_pattern": "git@git.graspishop.com:{group}/{project}.git",
    "project_list_command": "glab api projects --per-page 100 -f 'membership=true' -f 'simple=true' --jq '.[] | \"\\(.path_with_namespace)|\\(.name)\"'",
    "scenarios": {
      "in_project": {
        "condition": "当前目录在 iShop GitLab 项目内",
        "options": [
          {"label": "✅ 是，继续操作", "description": "使用当前项目"},
          {"label": "🔄 切换到其他项目", "description": "列出所有有权限的项目"}
        ]
      },
      "not_in_git": {
        "condition": "当前目录不在 Git 仓库内",
        "action": "列出用户有权限的所有项目让用户选择"
      },
      "not_ishop_gitlab": {
        "condition": "当前项目不在 iShop GitLab",
        "options": [
          {"label": "🔄 切换到其他项目", "description": "列出 iShop GitLab 上的项目"},
          {"label": "✏️ 手动输入项目路径", "description": "直接输入项目路径（如 igroup/ishop）"},
          {"label": "❌ 取消操作", "description": ""}
        ]
      },
      "issue_id_provided": {
        "condition": "用户提供了 Issue/MR ID",
        "search_command": "glab api issues --search {issue_id}",
        "options": [
          {"label": "✅ 是，继续操作", "description": "使用检测到的项目"},
          {"label": "🔄 切换到其他项目", "description": "列出其他项目"}
        ]
      }
    }
  },
  "selection_options": {
    "issue_type": [
      {"label": "🚀 feature", "description": "新功能开发"},
      {"label": "🐛 bug", "description": "Bug 修复"},
      {"label": "✨ improvement", "description": "优化改进"}
    ],
    "title_confirm": [
      {"label": "✅ 使用建议标题", "description": "[显示建议的标题]"},
      {"label": "✏️ 修改标题", "description": "手动输入新标题"}
    ],
    "branch_name_confirm": [
      {"label": "✅ 使用建议名称", "description": "[显示建议的分支名]"},
      {"label": "✏️ 修改分支名", "description": "手动输入新名称"}
    ],
    "create_draft_mr": [
      {"label": "✅ 创建 Draft MR", "description": "创建并关联分支"},
      {"label": "⏸️ 暂不创建 MR", "description": "仅创建 Issue"}
    ],
    "mark_ready": [
      {"label": "✅ 转为正式 MR", "description": "并请求审核"},
      {"label": "⏸️ 保持 Draft 状态", "description": "继续开发"}
    ],
    "merge_confirm": [
      {"label": "✅ 合并 MR", "description": "合并后自动删除分支、关闭 Issue"},
      {"label": "⏸️ 暂不合并", "description": "等待进一步确认"}
    ],
    "no_assignee": {"label": "👤 不指派", "description": "稍后指定"},
    "no_reviewer": {"label": "👤 不指定", "description": "稍后指定"},
    "skip_label": {"label": "⏭️ 跳过", "description": "不添加标签"}
  },
  "workflow": {
    "full_flow": {
      "name": "Issue → MR(Draft) → 分支 → 开发 → 合并",
      "steps": [
        {
          "step": 1,
          "name": "create_issue",
          "description": "创建 Issue 记录需求/问题",
          "commands": ["glab issue create"]
        },
        {
          "step": 2,
          "name": "create_draft_mr",
          "description": "创建 Draft MR 并自动创建关联分支",
          "commands": ["glab mr create --draft --create-source-branch"]
        },
        {
          "step": 3,
          "name": "checkout_branch",
          "description": "本地拉取关联分支开始开发",
          "commands": ["git fetch", "git checkout"]
        },
        {
          "step": 4,
          "name": "develop_and_push",
          "description": "开发并推送代码",
          "commands": ["git add", "git commit", "git push"]
        },
        {
          "step": 5,
          "name": "mark_ready",
          "description": "Draft MR 转正式状态，请求审核",
          "commands": ["glab mr ready", "通知审核人"]
        },
        {
          "step": 6,
          "name": "merge",
          "description": "审核通过后合并 MR",
          "commands": ["glab mr merge --delete-branch"]
        },
        {
          "step": 7,
          "name": "auto_close",
          "description": "自动关闭关联 Issue/MR/删除分支",
          "commands": []
        }
      ]
    }
  },
  "issue_types": [
    {
      "type": "feature",
      "label": "feature",
      "description": "新功能开发"
    },
    {
      "type": "bug",
      "label": "bug",
      "description": "Bug 修复"
    },
    {
      "type": "improvement",
      "label": "improvement",
      "description": "优化改进"
    }
  ],
  "branch_naming": {
    "pattern": "{issue-id}-{描述}",
    "examples": [
      "421-iShop开单神器",
      "974-BUG修改",
      "9750-商品性质档案"
    ],
    "note": "无类型前缀（feature/fix等），直接使用 Issue ID + 描述"
  },
  "mr_naming": {
    "draft_pattern": "Draft: Resolve \"{Issue名称}\"",
    "ready_pattern": "Resolve \"{Issue名称}\"",
    "examples": {
      "draft": "Draft: Resolve \"开发iShop开单神器\"",
      "ready": "Resolve \"开发iShop开单神器\""
    },
    "description_keywords": {
      "closes": "Closes #",
      "fixes": "Fixes #",
      "relates": "Relates to #"
    }
  },
  "trigger_keywords": {
    "issue_create": ["创建issue", "提issue", "记录问题", "新建issue", "创建一个问题"],
    "issue_query": ["查看issue", "我的issue", "待处理issue", "issue列表"],
    "mr_create": ["创建mr", "提交mr", "合并请求", "发起pr", "代码审查", "提mr"],
    "mr_query": ["查看mr", "我的mr", "待审核mr", "mr列表"],
    "branch_create": ["创建分支", "新建分支", "开发分支"],
    "full_flow": ["我要开发", "新功能", "修复bug", "开发一个"]
  },
  "constraints": {
    "require_issue_for_mr": {
      "enabled": false,
      "description": "创建 MR 时是否必须关联 Issue"
    },
    "squash_on_merge": {
      "enabled": false,
      "description": "合并时是否默认 squash commits"
    }
  }
}
