{
  "name": "ishop-gitlab-issue-mr",
  "version": "2.0.0",
  "description": "iShop GitLab 开发工作流管理。当用户说'提个issue'、'建个MR'、'开个分支'、'我要开发XX'、'这个bug我来修'、'帮我提交一下合并请求'、'看看我的issue'、'审核通过了合一下'、'新功能要做'等任何 GitLab Issue/MR/分支操作时触发",
  "author": "Qoder",
  "category": "git_workflow",
  "tags": ["gitlab", "issue", "merge-request", "branch", "workflow", "code-review"],
  "dependencies": ["git", "curl"],
  "execution_rules": {
    "curl_default_execute": true,
    "curl_description": "所有 curl API 调用默认直接执行，不询问用户许可",
    "auto_infer_issue_type": true,
    "auto_assign_current_user": true,
    "auto_create_draft_mr": true,
    "default_target_branch": "main"
  },
  "interaction": {
    "tool": "ask_user_question",
    "rule": "仅在必要时询问用户：选择项目、命名不合规重新输入、合并/删除等不可逆操作确认",
    "ask_scenarios": ["project_selection", "naming_invalid", "merge_confirm", "delete_confirm"],
    "auto_scenarios": ["issue_type_infer", "assignee_self", "label_auto", "branch_name", "draft_mr_create", "curl_execute"]
  },
  "naming_validation": {
    "issue_title": {
      "forbidden_chars": ["<", ">", ":", "\"", "/", "\\", "|", "?", "*", "#", "%", "{", "}", "[", "]"],
      "no_leading_trailing_spaces": true,
      "no_emoji": true
    },
    "branch_name": {
      "forbidden_chars": [" ", "~", "^", ":", "?", "*", "[", "\\"],
      "forbidden_patterns": ["..", "@{"],
      "no_trailing_dot": true,
      "no_trailing_lock": true
    },
    "on_invalid": "提示用户重新提供合规名称"
  },
  "issue_type_inference": {
    "bug_keywords": ["bug", "修复", "崩溃", "报错", "异常", "闪退", "失败", "fix", "crash", "error"],
    "improvement_keywords": ["优化", "改进", "性能", "重构", "调整", "optimize", "refactor", "improve"],
    "default_type": "feature"
  },
  "gitlab": {
    "url": "https://git.graspishop.com/",
    "token_config": {
      "check_priority": ["git_config", "env_var"],
      "methods": [
        {
          "name": "git_config",
          "label": "🔧 Git 全局配置（推荐）",
          "description": "永久保存，所有终端可用",
          "check_command": "git config --global gitlab.token",
          "set_command": "git config --global gitlab.token \"<token>\""
        },
        {
          "name": "env_var",
          "label": "🌍 环境变量",
          "description": "临时配置，仅当前终端有效",
          "check_command": "echo $GITLAB_TOKEN",
          "set_command": "export GITLAB_TOKEN=\"<token>\""
        }
      ],
      "create_url": "https://git.graspishop.com/-/profile/personal_access_tokens",
      "required_scopes": ["api"]
    }
  },
  "project_detection": {
    "method": "context_driven",
    "description": "优先从对话上下文推断项目，否则让用户从项目列表选择。不检测当前工作目录",
    "priority": [
      "1. 检查用户对话上下文中是否提及项目名称",
      "2. 调用 API 获取项目列表让用户选择"
    ],
    "project_list_api": "/api/v4/projects?membership=true&simple=true&per_page=100",
    "url_pattern": "https://git.graspishop.com/api/v4/projects/{url_encoded_path}"
  },
  "selection_options": {
    "issue_type": {
      "description": "自动推断，不询问用户",
      "inference_rule": "根据任务名称关键词自动推断，bug类/improvement类/默认feature"
    },
    "assignee": {
      "description": "自动指派给当前登录用户",
      "api": "/api/v4/user"
    },
    "title_confirm": {
      "description": "自动使用用户提供的名称，仅命名不合规时询问"
    },
    "branch_name_confirm": {
      "description": "自动生成分支名，仅命名不合规时询问"
    },
    "create_draft_mr": {
      "description": "自动创建 Draft MR，不询问用户"
    },
    "mark_ready": {
      "description": "自动执行，不询问用户"
    },
    "merge_confirm": [
      {"label": "✅ 合并 MR", "description": "合并后自动删除分支、关闭 Issue"},
      {"label": "⏸️ 暂不合并", "description": "等待进一步确认"}
    ],
    "no_assignee": {"description": "默认指派给当前用户，不提供不指派选项"},
    "no_reviewer": {"label": "👤 不指定", "description": "稍后指定"},
    "skip_label": {"label": "⏭️ 跳过", "description": "不添加标签"}
  },
  "workflow": {
    "full_flow": {
      "name": "Issue → MR(Draft) → 分支 → 开发 → 合并",
      "steps": [
        {
          "step": 1,
          "name": "get_current_user",
          "description": "获取当前登录用户信息",
          "auto": true,
          "api": "/api/v4/user"
        },
        {
          "step": 2,
          "name": "validate_naming",
          "description": "校验命名合规性",
          "auto": true,
          "ask_on_invalid": true
        },
        {
          "step": 3,
          "name": "infer_issue_type",
          "description": "根据名称关键词自动推断 Issue 类型",
          "auto": true
        },
        {
          "step": 4,
          "name": "create_issue",
          "description": "创建 Issue，自动指派给当前用户",
          "auto": true,
          "api": "POST /api/v4/projects/:id/issues"
        },
        {
          "step": 5,
          "name": "create_branch",
          "description": "创建关联分支",
          "auto": true,
          "api": "POST /api/v4/projects/:id/repository/branches"
        },
        {
          "step": 6,
          "name": "create_draft_mr",
          "description": "创建 Draft MR 并关联 Issue",
          "auto": true,
          "api": "POST /api/v4/projects/:id/merge_requests"
        },
        {
          "step": 7,
          "name": "checkout_branch",
          "description": "本地拉取关联分支开始开发",
          "commands": ["git fetch", "git checkout"]
        },
        {
          "step": 8,
          "name": "develop_and_push",
          "description": "开发并推送代码",
          "commands": ["git add", "git commit", "git push"]
        },
        {
          "step": 9,
          "name": "mark_ready",
          "description": "Draft MR 转正式状态",
          "auto": true,
          "api": "PUT /api/v4/projects/:id/merge_requests/:mr_id"
        },
        {
          "step": 10,
          "name": "merge",
          "description": "审核通过后合并 MR（需用户确认）",
          "auto": false,
          "api": "PUT /api/v4/projects/:id/merge_requests/:mr_id/merge"
        }
      ]
    }
  },
  "issue_types": [
    {
      "type": "feature",
      "label": "feature",
      "description": "新功能开发"
    },
    {
      "type": "bug",
      "label": "bug",
      "description": "Bug 修复"
    },
    {
      "type": "improvement",
      "label": "improvement",
      "description": "优化改进"
    }
  ],
  "branch_naming": {
    "pattern": "{issue-id}-{描述}",
    "examples": [
      "421-iShop开单神器",
      "974-BUG修改",
      "9750-商品性质档案"
    ],
    "note": "无类型前缀（feature/fix等），直接使用 Issue ID + 描述"
  },
  "mr_naming": {
    "draft_pattern": "Draft: Resolve \"{Issue名称}\"",
    "ready_pattern": "Resolve \"{Issue名称}\"",
    "examples": {
      "draft": "Draft: Resolve \"开发iShop开单神器\"",
      "ready": "Resolve \"开发iShop开单神器\""
    },
    "description_keywords": {
      "closes": "Closes #",
      "fixes": "Fixes #",
      "relates": "Relates to #"
    }
  },
  "trigger_keywords": {
    "issue_create": ["提个issue", "建个issue", "记一下这个问题", "帮我提个issue", "有个需求要记录", "创建一个问题"],
    "issue_query": ["看看我的issue", "我有哪些issue", "待处理的issue", "issue列表", "有什么issue"],
    "mr_create": ["提个MR", "建个合并请求", "帮我提交一下MR", "发个PR", "代码写好了提交审核", "提一下MR"],
    "mr_query": ["看看我的MR", "有哪些MR要审", "待审核的MR", "MR列表", "我提的MR怎么样了"],
    "branch_create": ["开个分支", "建个分支", "拉个开发分支"],
    "full_flow": ["我要开发", "我要修改", "我要修复", "我要解决", "修改XX的bug", "修复XX", "解决XX问题", "新功能", "开发一个", "帮我走一下开发流程"]
  },
  "constraints": {
    "require_issue_for_mr": {
      "enabled": false,
      "description": "创建 MR 时是否必须关联 Issue"
    },
    "squash_on_merge": {
      "enabled": false,
      "description": "合并时是否默认 squash commits"
    }
  }
}
