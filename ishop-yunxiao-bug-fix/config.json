{
  "name": "ishop-yunxiao-bug-fix",
  "version": "1.4.0",
  "description": "云效（阿里云DevOps平台）Bug工作项全生命周期管理技能，涵盖工作项查询、详情获取、评论提交、状态流转等操作流程",
  "author": "Qoder",
  "category": "project_management",
  "tags": ["yunxiao", "devops", "bug", "workitem", "阿里云"],
  "dependencies": ["mcp-ram"],
  "triggers": [
    "我有bug吗",
    "有没有bug",
    "查看bug",
    "看看bug",
    "bug列表",
    "有bug吗",
    "我的bug",
    "查看我的bug"
  ],
  "parameters": {
    "project_name": {
      "type": "string",
      "required": false,
      "default": "iShop ERP",
      "description": "默认项目名称"
    },
    "status_filter": {
      "type": "string",
      "required": false,
      "default": "28,100005,30,100010",
      "description": "默认查询的Bug状态ID（待确认、待处理、重新打开、处理中）"
    }
  },
  "workitem_status": {
    "pending_confirm": {
      "id": 28,
      "name": "待确认",
      "description": "新建Bug的初始状态",
      "default_query": true
    },
    "pending_process": {
      "id": 100005,
      "name": "待处理",
      "description": "已确认待开发处理",
      "default_query": true
    },
    "processing": {
      "id": 100010,
      "name": "处理中",
      "description": "开发人员正在修复",
      "default_query": true
    },
    "reopened": {
      "id": 30,
      "name": "重新打开",
      "description": "验证未通过被重新打开",
      "default_query": true
    },
    "fixed": {
      "id": 29,
      "name": "已修复",
      "description": "修复完成待验证",
      "default_query": false
    },
    "closed": {
      "id": 100085,
      "name": "已关闭",
      "description": "验证通过或无需修复",
      "default_query": false
    }
  },
  "workflow": {
    "steps": [
      {
        "name": "get_basic_info",
        "description": "获取组织ID和项目信息",
        "tools": ["mcp_RAM_get_current_organization_info", "mcp_RAM_search_projects"]
      },
      {
        "name": "query_workitems",
        "description": "查询Bug工作项列表",
        "tools": ["mcp_RAM_search_workitems"]
      },
      {
        "name": "process_loop",
        "description": "循环处理Bug列表"
      },
      {
        "name": "get_detail",
        "description": "获取工作项详情、附件和历史评论",
        "tools": ["mcp_RAM_get_work_item", "mcp_RAM_list_workitem_attachments", "mcp_RAM_get_workitem_file", "mcp_RAM_list_work_item_comments"]
      },
      {
        "name": "handle_action",
        "description": "处理用户选择的操作（修复/转交/无法复现/不是问题/需要更多信息/重复/延期）"
      },
      {
        "name": "submit_comment",
        "description": "提交修复说明或无法复现说明",
        "tools": ["mcp_RAM_create_work_item_comment"]
      },
      {
        "name": "update_status",
        "description": "更新工作项状态",
        "tools": ["mcp_RAM_update_work_item"]
      }
    ]
  },
  "comment_templates": {
    "fix_comment": {
      "title": "修复说明",
      "sections": ["问题原因", "修改描述", "影响范围", "自测结果", "关联提交"],
      "format": "plain_text"
    },
    "transfer_comment": {
      "title": "转交说明",
      "sections": ["转交原因"],
      "format": "plain_text"
    },
    "cannot_reproduce_comment": {
      "title": "无法复现说明",
      "sections": ["复现结果", "测试环境", "测试操作", "结论"],
      "format": "plain_text"
    },
    "not_issue_comment": {
      "title": "不是问题说明",
      "sections": ["分析结果", "问题描述", "实际行为", "原因说明", "建议"],
      "format": "plain_text"
    },
    "need_more_info_comment": {
      "title": "需要更多信息说明",
      "sections": ["状态", "缺少的信息"],
      "format": "plain_text"
    },
    "duplicate_comment": {
      "title": "重复Bug说明",
      "sections": ["分析结果", "原始Bug", "重复说明", "建议"],
      "format": "plain_text"
    },
    "deferred_comment": {
      "title": "延期处理说明",
      "sections": ["处理结果", "延期原因", "预计处理时间", "当前影响"],
      "format": "plain_text"
    }
  },
  "constraints": {
    "comment_format": {
      "type": "plain_text",
      "description": "云效平台不支持Markdown渲染，评论内容必须使用纯文本格式"
    },
    "responsibility_scope": {
      "description": "仅处理分配给当前用户的Bug工作项，不主动介入他人工作项"
    },
    "confirmation_required": {
      "description": "所有涉及外部操作（修改代码、提交评论、更新状态、转交负责人）的步骤，必须先向用户展示具体内容并获得确认后才能执行"
    }
  }
}
